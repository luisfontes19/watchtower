{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug adapter",
            "type": "node",
            "request": "launch",
            "program": "${workspaceRoot}/src/phpDebug.ts",
            "cwd": "${workspaceRoot}",
            "args": [
                "--server=4711"
            ],
            "env": {
                "NODE_ENV": "development"
            },
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ],
            "preLaunchTask": "npm: watch",
            "presentation": {
                "hidden": false,
                "group": "",
                "order": 1
            }
        }
    ]
}
