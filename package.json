{
  "name": "watchtower",
  "displayName": "Watchtower",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "watchtower.analyze",
        "title": "Watchtower: Analyze Workspace"
      },
      {
        "command": "watchtower.resetAcknowledgement",
        "title": "Watchtower: Reset Project Acknowledgement"
      },
      {
        "command": "watchtower.enableProtections",
        "title": "Watchtower: Enable Protections"
      },
      {
        "command": "watchtower.disableProtections",
        "title": "Watchtower: Disable Protections"
      },
      {
        "command": "watchtower.checkStatus",
        "title": "Watchtower: Check Protection Status"
      }
    ],
    "configuration": {
      "title": "Watchtower",
      "properties": {
        "watchtower.projectAcknowledged": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Whether the user has acknowledged the security scan results for this project."
        },
        "watchtower.protectionsDisabled": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Whether all security protections (scans and runtime monitoring) are disabled for this project."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "rm -rf out && pnpm run compile-tests && pnpm run compile",
    "check-types": "tsc --noEmit",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/minimatch": "^6.0.0",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.4"
  }
}
