{
  "name": "watchtower",
  "displayName": "Watchtower - VSCode Security Scanner",
  "description": "Protect your development environment from malicious configurations and hidden threats. Scans for invisible code, suspicious tasks, dangerous settings, and compromised configurations.",
  "version": "0.0.4",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "data/images/logo.png",
  "publisher": "luisfontes19",
  "keywords": [
    "security",
    "scanner",
    "malware",
    "protection",
    "invisible code",
    "configuration security",
    "workspace security",
    "threat detection",
    "vscode security",
    "devcontainer",
    "agents",
    "ai",
    "vibecoding",
    "vibe",
    "supply chain"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/luisfontes19/watchtower.git"
  },
  "bugs": {
    "url": "https://github.com/luisfontes19/watchtower/issues"
  },
  "homepage": "https://github.com/luisfontes19/watchtower",
  "author": {
    "name": "Luis Fontes"
  },
  "license": "MIT",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Watchtower",
      "properties": {
        "watchtower.enableStartupScans": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic security scans when opening workspaces"
        },
        "watchtower.inlineFindings": {
          "type": "string",
          "description": "Control the display of inline findings in the editor",
          "enum": [
            "all",
            "invisible",
            "none"
          ],
          "default": "invisible"
        }
      }
    },
    "commands": [
      {
        "command": "watchtower.scan",
        "title": "Watchtower: Scan Workspace"
      },
      {
        "command": "watchtower.enableWorkspaceStartupScan",
        "title": "Watchtower: Enable Workspace Startup Scan"
      },
      {
        "command": "watchtower.disableWorkspaceStartupScan",
        "title": "Watchtower: Disable Workspace Startup Scan"
      },
      {
        "command": "watchtower.enableWorkspaceRealTimeDetection",
        "title": "Watchtower: Enable Workspace Real-Time Protections. Will monitor for file changes and perform automatic scans"
      },
      {
        "command": "watchtower.disableWorkspaceRealTimeDetection",
        "title": "Watchtower: Disable Workspace Real-Time Detection. Will not perform scans"
      }
    ]
  },
  "scripts": {
    "bump:patch": "npm version patch",
    "bump:minor": "npm version minor",
    "bump:major": "npm version major",
    "publish": "pnpm run package && vsce publish --no-dependencies",
    "compile": "pnpm run check-types && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && node esbuild.js --production && vsce package --no-dependencies",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "rm -rf out && pnpm run compile-tests && pnpm run compile",
    "check-types": "tsc --noEmit",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/minimatch": "^6.0.0",
    "jsonc-parser": "^3.3.1",
    "minimatch": "^10.2.4"
  }
}
